            <encoding attr='space' class='0' field='[federated.12ss2x41mob9ds1a3s94y07vd3l5].[usr:Calculation_0149851578302493:qk:9]' field-type='quantitative' max='349.00997735220398' min='-63.950328858206156' range-type='fixed' scope='rows' type='space' />
