          <formatted-text>
            <run>Case Fatality Rate</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='COVID_US_cases' name='federated.12ss2x41mob9ds1a3s94y07vd3l5' />
          </datasources>
          <datasource-dependencies datasource='federated.12ss2x41mob9ds1a3s94y07vd3l5'>
            <column caption='CFR_14d_pct' datatype='real' name='[Calculation_0149851578302493]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF WINDOW_SUM(SUM(ZN([new_confirmed])), -20, -14) = 0 THEN NULL&#13;&#10;ELSE&#13;&#10;100 * WINDOW_SUM(SUM(ZN([new_deceased])), -6, 0)&#13;&#10;/ WINDOW_SUM(SUM(ZN([new_confirmed])), -20, -14)&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Date' datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column caption='New Confirmed' datatype='integer' name='[new_confirmed]' role='measure' type='quantitative' />
            <column caption='New Deceased' datatype='integer' name='[new_deceased]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='None' name='[none:date:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0149851578302493]' derivation='User' name='[usr:Calculation_0149851578302493:qk:9]' pivot='key' type='quantitative'>
