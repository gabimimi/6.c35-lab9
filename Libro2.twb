      <aliases enabled='yes' />
      <column caption='Active_cases' datatype='integer' name='[Calculation_0149851555160069]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(ZN([cumulative_confirmed])) - SUM(ZN([cumulative_deceased])) - [Calculation_0149851559079942]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='cumulative_recvered_fixed' datatype='integer' name='[Calculation_0149851559079942]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_MAX(SUM(ZN([cumulative_recovered])))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Month' datatype='datetime' name='[Calculation_0149851560566791]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [date])' />
      </column>
      <column caption='Week of Month' datatype='integer' name='[Calculation_0149851560644616]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;week&apos;, DATETRUNC(&apos;month&apos;, [date]), [date]) + 1' />
      </column>
      <column caption='Weekday (num)' datatype='integer' name='[Calculation_0149851560742921]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;weekday&apos;, [date])' />
      </column>
      <column caption='Weekday' datatype='string' name='[Calculation_0149851560824842]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [date])' />
      </column>
      <column caption='WeekStart' datatype='datetime' name='[Calculation_0149851562545163]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;, [date])' />
      </column>
      <column caption='month label' datatype='string' name='[Calculation_0149851563720716]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;,[date]) + &quot; &quot; + STR(DATEPART(&apos;year&apos;,[date]))' />
      </column>
      <column caption='month start' datatype='datetime' name='[Calculation_0149851563806733]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[date])' />
      </column>
      <column caption='week of month (discrete)' datatype='integer' name='[Calculation_0149851563933710]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;week&apos;, DATETRUNC(&apos;month&apos;,[date]), [date]) + 1' />
      </column>
      <column caption='MonthNum' datatype='integer' name='[Calculation_0149851568193551]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;month&apos;, [date])' />
      </column>
      <column caption='Year' datatype='integer' name='[Calculation_0149851568267280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;year&apos;, [date])' />
      </column>
      <column caption='MonthRow' datatype='integer' name='[Calculation_0149851568332817]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT( ( [Calculation_0149851568193551] - 1 ) / 4 )' />
      </column>
      <column caption='MonthCol' datatype='integer' name='[Calculation_0149851568406546]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0149851568193551] - 1) % 4 + 1' />
      </column>
      <column caption='MonthName' datatype='string' name='[Calculation_0149851568455699]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;,[date])' />
      </column>
      <column caption='WeekOfMonth' datatype='integer' name='[Calculation_0149851568533524]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;week&apos;, DATETRUNC(&apos;month&apos;, [date]), [date]) + 1' />
      </column>
      <column caption='Month Label (first week only): ' datatype='string' name='[Calculation_0149851570196502]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0149851568533524] = 1 THEN DATENAME(&apos;month&apos;,[date]) END' />
      </column>
      <column caption='Cases_14d_ago' datatype='integer' name='[Calculation_0149851577458714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOOKUP(SUM(ZN([new_confirmed])), -14)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='CFR_14d_pct' datatype='real' name='[Calculation_0149851578302493]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF WINDOW_SUM(SUM(ZN([new_confirmed])), -20, -14) = 0 THEN NULL&#13;&#10;ELSE&#13;&#10;100 * WINDOW_SUM(SUM(ZN([new_deceased])), -6, 0)&#13;&#10;/ WINDOW_SUM(SUM(ZN([new_confirmed])), -20, -14)&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='DayOfYear' datatype='integer' name='[Calculation_0149851582263333]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;dayofyear&apos;,[date])' />
      </column>
      <column caption='Trend_Top_2020' datatype='integer' name='[Calculation_0149851582402598]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATEPART(&apos;year&apos;,[date]) = 2020 THEN [new_confirmed] END' />
      </column>
      <column caption='Trend_Bottom_2021' datatype='integer' name='[Calculation_0149851582988327]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATEPART(&apos;year&apos;,[date]) = 2021 THEN [new_confirmed] END' />
      </column>
      <column caption='trend_2022' datatype='integer' name='[Calculation_0149851590176810]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATEPART(&apos;year&apos;,[date]) = 2022 THEN [new_confirmed] END' />
      </column>
